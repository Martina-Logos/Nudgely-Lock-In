// ─────────────────────────────────────────────────────────────────────────────
// Nudgely · prisma/schema.prisma
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum UserRole {
  Student
  Professional
  Creator
  Entrepreneur
}

enum Temperament {
  Sanguine
  Choleric
  Melancholic
  Phlegmatic
}

enum PersonalityVibe {
  Soft
  Bold
}

enum FocusTime {
  Morning
  Afternoon
  Evening
  Night
}

enum EmotionalState {
  Anxious
  Energetic
  Calm
  Overwhelmed
}

enum Distraction {
  SocialMedia
  RacingThoughts
  OtherPeople
  Perfectionism
}

enum MainGoal {
  StayingFocused
  BeatingProcrastination
  BuildingHabits
  ManagingADHD
}

enum Drive {
  OnFire      // Drive 1 — Urgent
  DueSoon     // Drive 2 — Deadline
  LowLift     // Drive 3 — Admin
  OpenSpace   // Drive 4 — Creative
}

enum TaskStatus {
  Todo
  WorkingOnIt
  PushedBack
  StuckOnThis
  Done
}

enum TaskPriority {
  NonNegotiable
  GoodToDo
  IfIGetThere
}

enum HabitType {
  Build
  Quit
}

enum HabitStrength {
  Weak
  Moderate
  High
}

enum HabitFrequency {
  Daily
  Weekdays
  Custom
}

enum MeditationMode {
  Focus
  Calm
  Sleep
  Energy
}

enum OtpPurpose {
  EmailVerification
  PasswordReset
}

// ─────────────────────────────────────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  passwordHash    String?
  displayName     String
  username        String?  @unique
  avatarUrl       String?
  timezone        String   @default("UTC")
  role            UserRole?
  isEmailVerified Boolean  @default(false)
  isOnboarded     Boolean  @default(false)

  // Onboarding preferences
  focusTime       FocusTime?
  emotionalState  EmotionalState?
  distractions    Distraction[]
  mainGoal        MainGoal?
  weeklyGoal      String?
  personalityVibe PersonalityVibe?

  // Cognitive profile
  temperament     Temperament?
  iqScore         Int?
  eqScore         Int?
  sqScore         Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  refreshTokens      RefreshToken[]
  otpCodes           OtpCode[]
  tasks              Task[]
  habits             Habit[]
  routines           Routine[]
  journalEntries     JournalEntry[]
  focusSessions      FocusSession[]
  meditationSessions MeditationSession[]
  weeklyReports      WeeklyReport[]

  @@map("users")
}

// ─────────────────────────────────────────────────────────────────────────────
// AUTH — TOKENS & OTP
// ─────────────────────────────────────────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model OtpCode {
  id        String     @id @default(uuid())
  code      String
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  purpose   OtpPurpose @default(EmailVerification)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime   @default(now())

  @@index([userId])
  @@map("otp_codes")
}

// ─────────────────────────────────────────────────────────────────────────────
// TASKS
// ─────────────────────────────────────────────────────────────────────────────

model Task {
  id               String       @id @default(uuid())
  userId           String
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  title            String
  naturalInput     String?
  drive            Drive        @default(OnFire)
  status           TaskStatus   @default(Todo)
  priority         TaskPriority @default(GoodToDo)
  estimatedMinutes Int?
  dueDate          DateTime?
  completedAt      DateTime?
  aiSuggested      Boolean      @default(false)
  aiNudge          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subtasks      Subtask[]
  focusSessions FocusSession[]

  @@index([userId])
  @@index([userId, drive])
  @@index([userId, status])
  @@map("tasks")
}

model Subtask {
  id               String    @id @default(uuid())
  taskId           String
  task             Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  title            String
  estimatedMinutes Int?
  completed        Boolean   @default(false)
  completedAt      DateTime?
  order            Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId])
  @@map("subtasks")
}

// ─────────────────────────────────────────────────────────────────────────────
// HABITS & ROUTINES
// ─────────────────────────────────────────────────────────────────────────────

model Habit {
  id         String         @id @default(uuid())
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  name       String
  emoji      String         @default("✅")
  type       HabitType      @default(Build)
  frequency  HabitFrequency @default(Daily)
  strength   HabitStrength  @default(Weak)
  streak     Int            @default(0)
  bestStreak Int            @default(0)
  isActive   Boolean        @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  completions  HabitCompletion[]
  routineItems RoutineItem[]

  @@index([userId])
  @@map("habits")
}

model HabitCompletion {
  id          String   @id @default(uuid())
  habitId     String
  habit       Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  completedAt DateTime @default(now())
  date        String   // YYYY-MM-DD — prevents duplicate completions per day

  @@unique([habitId, date])
  @@index([habitId])
  @@map("habit_completions")
}

model Routine {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String
  time      String?  // "07:00"
  type      String   @default("Morning")
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items RoutineItem[]

  @@index([userId])
  @@map("routines")
}

model RoutineItem {
  id        String  @id @default(uuid())
  routineId String
  routine   Routine @relation(fields: [routineId], references: [id], onDelete: Cascade)
  habitId   String?
  habit     Habit?  @relation(fields: [habitId], references: [id], onDelete: SetNull)
  label     String
  order     Int     @default(0)

  @@index([routineId])
  @@map("routine_items")
}

// ─────────────────────────────────────────────────────────────────────────────
// JOURNAL
// ─────────────────────────────────────────────────────────────────────────────

model JournalEntry {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  text         String?
  tags         String[]
  moodScore    Int      // 1–5
  sleepQuality Int?     // 1–10
  date         String   // YYYY-MM-DD

  aiInsight    String?
  aiPromptUsed Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId])
  @@map("journal_entries")
}

// ─────────────────────────────────────────────────────────────────────────────
// SESSIONS
// ─────────────────────────────────────────────────────────────────────────────

model FocusSession {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId          String?
  task            Task?     @relation(fields: [taskId], references: [id], onDelete: SetNull)

  durationMinutes Int
  completed       Boolean   @default(true)
  interrupted     Boolean   @default(false)
  startedAt       DateTime
  completedAt     DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, startedAt])
  @@map("focus_sessions")
}

model MeditationSession {
  id              String         @id @default(uuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  mode            MeditationMode
  durationMinutes Int
  completed       Boolean        @default(true)
  startedAt       DateTime
  completedAt     DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("meditation_sessions")
}

// ─────────────────────────────────────────────────────────────────────────────
// WEEKLY REPORT
// ─────────────────────────────────────────────────────────────────────────────

model WeeklyReport {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  weekStart     DateTime
  weekEnd       DateTime

  totalFocusMin Int      @default(0)
  tasksDone     Int      @default(0)
  avgMood       Float    @default(0)

  dailyFocusData Json    @default("[]")
  moodTrendData  Json    @default("[]")
  wins           String[]
  tips           String[]
  aiSummary      String?
  suggestions    String?

  generatedAt DateTime @default(now())

  @@unique([userId, weekStart])
  @@index([userId])
  @@map("weekly_reports")
}
